# PINE Backend - Environment Variables
# Copy this file to .env and fill in the values

# =============================================================================
# CORE
# =============================================================================

# Environment: development, staging, production
ENVIRONMENT=development

# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://pine:pine@localhost:5432/pine_db

# PostgreSQL connection for LangGraph checkpointer (can be same as DATABASE_URL)
CHECKPOINT_SAVER_URL=postgresql://pine:pine@localhost:5432/pine_cs

# =============================================================================
# OPENROUTER
# =============================================================================

# OpenRouter base URL (API keys are stored per organization in the database)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================

# Secret key for JWT signing (CHANGE THIS IN PRODUCTION!)
JWT_SECRET=your-super-secret-key-change-in-production

# JWT algorithm
JWT_ALGORITHM=HS256

# Token expiration time in hours
JWT_EXPIRATION_HOURS=24

# =============================================================================
# EMAIL (RESEND)
# =============================================================================

# Resend API key (https://resend.com)
RESEND_API_KEY=re_your_api_key

# Sender email address
RESEND_FROM_EMAIL=PINE <noreply@yourdomain.com>

# Frontend URL for email links
APP_URL=http://localhost:3000

# =============================================================================
# EMAIL VERIFICATION
# =============================================================================

# Token expiration time in hours
EMAIL_VERIFICATION_TOKEN_EXPIRATION_HOURS=24

# Rate limit for resending verification emails in seconds
EMAIL_VERIFICATION_RATE_LIMIT_SECONDS=60

# =============================================================================
# PASSWORD RESET
# =============================================================================

# Token expiration time in hours
PASSWORD_RESET_TOKEN_EXPIRATION_HOURS=1

