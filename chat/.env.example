# Configuração do LangGraph
# Para desenvolvimento local: aponte diretamente para seu servidor LangGraph local
NEXT_PUBLIC_API_URL=http://localhost:2024
NEXT_PUBLIC_ASSISTANT_ID=agent

# Configuração do LangGraph para Produção (início rápido) - Descomente para usar
# NEXT_PUBLIC_ASSISTANT_ID="agent"
# Esta deve ser a URL de implantação do seu servidor LangGraph (apenas lado do servidor)
# LANGGRAPH_API_URL="https://my-agent.default.us.langgraph.app"
# Esta deve ser a URL do seu site + "/api". É assim que o cliente se conecta ao proxy da API
# NEXT_PUBLIC_API_URL="https://my-website.com/api"
# Chave de API do LangSmith - apenas lado do servidor, tratada pelo proxy da API (NÃO prefixe com NEXT_PUBLIC_)
# LANGSMITH_API_KEY="lsv2_..."

# Configuração do Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
